{
  "name": "root",
  "private": true,
  "engines": {
    "node": ">=14"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "pnpm -w -r run build",
    "clean": "pnpm -w -r run clean",
    "release": "pnpm -w -r publish",
    "alpha": "pnpm -w -r publish --tag alpha",
    "lint": "pnpm -w -r run lint",
    "format": "pnpm -w -r run format"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.9"
  }
}
